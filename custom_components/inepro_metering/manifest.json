{
  "domain": "inepro_metering",
  "name": "inepro Metering",
  "codeowners": [
    "@ineprometering"
  ],
  "config_flow": true,
  "documentation": "https://github.com/ineprometering/home-assistant-inepro-metering#readme",
  "issue_tracker": "https://github.com/ineprometering/home-assistant-inepro-metering/issues",
  "integration_type": "hub",
  "iot_class": "local_polling",
  "dependencies": [
    "bluetooth_adapters"
  ],
  "bluetooth": [
    {
      "connectable": true,
      "local_name": "IM-*"
    }
  ],
  "zeroconf": [
    "_modbus._tcp.local."
  ],
  "loggers": [
    "bleak",
    "inepro_metering",
    "pymodbus"
  ],
  "requirements": [
    "inepro-metering==0.1.1",
    "bleak>=2.1,<3",
    "bleak-retry-connector>=4.6,<5",
    "pymodbus>=3.11.2",
    "pyserial>=3.5,<4"
  ],
  "version": "0.1.1"
}
